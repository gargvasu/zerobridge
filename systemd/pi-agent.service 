[Unit]
Description=mac.hid — Pi Agent Daemon
Documentation=https://github.com/gargvasu/zerobridge
After=network.target mac-hid-setup.service
Requires=mac-hid-setup.service

[Service]
Type=simple
User=root
Environment=HOME=/home/{{USER}}
ExecStart=/usr/local/bin/pi-agent
ExecStopPost=/bin/rm -f /tmp/zerobridge.sock
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=pi-agent

[Install]
WantedBy=multi-user.target