[Unit]
Description=ZeroBridge Pi Agent — HID + Serial + SSH daemon
Documentation=https://github.com/gargvasu/zerobridge
After=network.target multi-hid-setup.service
Requires=multi-hid-setup.service

[Service]
Type=simple
User=root
Environment=HOME=/home/{{USER}}
ExecStart=/usr/local/bin/pi-agent
ExecStopPost=/bin/rm -f /tmp/zerobridge.sock
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=pi-agent

[Install]
WantedBy=multi-user.target