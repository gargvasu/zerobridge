# ZeroBridge Configuration
# Copy to ~/.config/zerobridge/config.toml and edit

[ssh]
# SSH user on the Mac
user       = "pi"
# Path to SSH private key on Pi Zero
key        = "/home/pi/.ssh/id_ed25519"
port       = 22
timeout_ms = 5000

[hosts]
# Mac Mini IP over USB tether (primary — fastest)
usb  = "mac.hid"
# Mac Mini hostname or IP over WiFi (fallback)
wifi = "192.168.0.100"

[serial]
device            = "/dev/ttyGS0"
timeout_ms        = 3000
cursor_timeout_ms = 1000
max_retries       = 2

[hid]
keyboard = "/dev/hidg0"
mouse    = "/dev/hidg1"
media    = "/dev/hidg2"

# Bridge routing mode
# "websocket" — WebSocket only (fastest, requires zb-agent serve on Mac)
# "serial"    — Serial only (legacy)
# "ssh"       — SSH only (legacy)
# "hybrid"    — WebSocket primary, SSH fallback (recommended)
[bridge]
mode = "hybrid"

# WebSocket connection to Mac agent
# Only used when bridge mode includes websocket
# Start on Mac: zb-agent serve --port 8082 --bind 169.254.206.1
[websocket]
url        = "ws://mac.hid:8082"
timeout_ms = 2000